{
  "app-id": "land.rob.patch",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "sdk": "org.gnome.Sdk",
  "command": "patch",
  "finish-args": [
    "--share=ipc",
    "--share=network",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--socket=pulseaudio",
    "--device=dri",
    "--talk-name=org.freedesktop.Notifications",
    "--talk-name=org.freedesktop.secrets",
    "--talk-name=org.unifiedpush.Distributor.*",
    "--talk-name=org.sigxcpu.Feedback",
    "--own-name=land.rob.patch",
    "--filesystem=xdg-cache/gsconnect:ro",
    "--filesystem=xdg-data/evolution:ro",
    "--filesystem=xdg-config/evolution:ro",
    "--talk-name=org.gnome.evolution.dataserver.*",
    "--talk-name=org.gnome.OnlineAccounts"
  ],
  "cleanup": [
    "/include",
    "/lib/pkgconfig",
    "/man",
    "/share/doc",
    "/share/gtk-doc",
    "*.la",
    "*.a",
    "/libexec/evolution-*",
    "/libexec/evolution-source-registry",
    "/libexec/evolution-addressbook-factory",
    "/libexec/evolution-calendar-factory",
    "/share/dbus-1/services/org.gnome.evolution.*",
    "/etc/xdg/autostart/evolution-*"
  ],
  "modules": [
    {
      "name": "blueprint-compiler",
      "buildsystem": "meson",
      "cleanup": ["*"],
      "sources": [
        {
          "type": "git",
          "url": "https://gitlab.gnome.org/jwestman/blueprint-compiler.git",
          "tag": "v0.16.0"
        }
      ]
    },
    {
      "name": "evolution-data-server",
      "buildsystem": "cmake-ninja",
      "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DENABLE_CALENDAR=OFF",
        "-DENABLE_CANBERRA=OFF",
        "-DENABLE_FILE_LOCKING=fcntl",
        "-DENABLE_GOA=OFF",
        "-DENABLE_GOOGLE_AUTH=OFF",
        "-DENABLE_GTK=OFF",
        "-DENABLE_GTK4=OFF",
        "-DENABLE_INSTALLED_TESTS=OFF",
        "-DENABLE_INTROSPECTION=ON",
        "-DENABLE_OAUTH2_WEBKITGTK4=OFF",
        "-DENABLE_TESTS=OFF",
        "-DENABLE_VALA_BINDINGS=ON",
        "-DENABLE_WEATHER=OFF",
        "-DENABLE_GTK_DOC=OFF",
        "-DENABLE_EXAMPLES=OFF",
        "-DWITH_LIBDB=OFF",
        "-DWITH_OPENLDAP=OFF",
        "-DWITH_PRIVATE_DOCS=OFF",
        "-DWITH_SYSTEMDUSERUNITDIR=no"
      ],
      "cleanup": [
        "/bin",
        "/libexec",
        "/share/dbus-1/services/org.gnome.evolution.*",
        "/share/locale"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://download.gnome.org/sources/evolution-data-server/3.58/evolution-data-server-3.58.3.tar.xz",
          "sha256": "da136d1190d9e8b09499452f6058e24eee6b77f441a8c769f74a52451bf379f1"
        },
        {
          "type": "shell",
          "commands": [
            "sed -i 's/^pkg_check_modules(CALENDAR REQUIRED/#&/' CMakeLists.txt",
            "sed -i 's/^set(CALENDAR_CFLAGS.*LIBICAL_GLIB/#&/' CMakeLists.txt"
          ]
        }
      ]
    },
    {
      "name": "libfolks",
      "buildsystem": "meson",
      "config-opts": [
        "-Dbluez_backend=false",
        "-Dofono_backend=false",
        "-Dtelepathy_backend=false",
        "-Deds_backend=true",
        "-Dimport_tool=false",
        "-Dinspect_tool=false",
        "-Dtests=false",
        "-Dinstalled_tests=false",
        "-Ddocs=false"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://download.gnome.org/sources/folks/0.15/folks-0.15.9.tar.xz",
          "sha256": "2311b37355c351f33f163fdc394874a22a0a0682c319493d6d8a6e420711415f"
        }
      ]
    },
    "python3-deps.json",
    {
      "name": "patch",
      "buildsystem": "meson",
      "sources": [
        {
          "type": "dir",
          "path": "../.."
        }
      ]
    }
  ]
}
