<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>land.rob.patch</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <name>Patch</name>
  <summary>JMP.chat phone client for GNOME mobile</summary>
  <description>
    <p>Patch turns a JMP.chat account into a phone on Linux mobile: dialer,
    SMS, MMS, voicemail. PSTN-first interface with XMPP hidden as the
    transport.</p>
    <p>Built around mod_cloud_notify_unifiedpush + KUnifiedPush for
    self-hosted push notifications. No FCM, no APNs, no external push
    services.</p>
  </description>
  <launchable type="desktop-id">land.rob.patch.desktop</launchable>
  <categories>
    <category>Network</category>
    <category>Telephony</category>
    <category>InstantMessaging</category>
  </categories>
  <requires>
    <display_length compare="ge">360</display_length>
  </requires>
  <recommends>
    <control>keyboard</control>
    <control>pointing</control>
    <control>touch</control>
  </recommends>
  <developer_name>Rob</developer_name>
  <url type="homepage">https://codeberg.org/robland/patch</url>
  <url type="bugtracker">https://codeberg.org/robland/patch/issues</url>
  <content_rating type="oars-1.1"/>
  <releases>
    <release version="0.1.0" date="2026-05-21">
      <description>
        <p>Initial scaffold.</p>
      </description>
    </release>
  </releases>
</component>
